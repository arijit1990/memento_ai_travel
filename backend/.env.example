# ══════════════════════════════════════════════════════════════════════════════
# Memento AI — Backend environment variables
# Rename to .env and place in /backend folder, or paste into Vercel env vars.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase (auth + database) ────────────────────────────────────────────────
# All four values are in Supabase dashboard → Settings → API

# Project URL — "Project URL" field
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role key — "service_role" key (secret — never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — used to verify user tokens locally (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=

# ── LLM API keys ──────────────────────────────────────────────────────────────

# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_AI_KEY=

# OpenAI — https://platform.openai.com/api-keys (needed for default fallback)
OPENAI_API_KEY=

# Anthropic — only needed if LLM_FALLBACK_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── App config ────────────────────────────────────────────────────────────────

# Your deployed frontend URL — used to configure CORS and share links
# For local dev: http://localhost:3000  |  For Vercel: https://your-app.vercel.app
FRONTEND_BASE_URL=http://localhost:3000

# Webhook URL for trip PDF/email export — leave blank to disable
EXPORT_WEBHOOK_URL=

# ── LLM model config — A/B testing ────────────────────────────────────────────
# Supported providers: gemini, openai, anthropic

LLM_PRIMARY_PROVIDER=gemini
LLM_PRIMARY_MODEL=gemini-2.5-flash

LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4o

LLM_INTAKE_PROVIDER=gemini
LLM_INTAKE_MODEL=gemini-2.5-flash
