# ══════════════════════════════════════════════════════════════════════════════
# Memento AI — Backend environment variables
# Rename to .env and place in /backend folder, or paste into Vercel env vars.
# ══════════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────────

# MongoDB connection string — Atlas dashboard → cluster → Connect → Drivers
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name (created automatically on first write)
DB_NAME=memento

# Google AI Studio API key — https://aistudio.google.com/apikey
GOOGLE_AI_KEY=

# OpenAI API key — https://platform.openai.com/api-keys (needed for default fallback)
OPENAI_API_KEY=

# Supabase JWT secret — Supabase dashboard → Settings → API → JWT Secret
# Used to verify user tokens locally — no outbound call needed at runtime
SUPABASE_JWT_SECRET=

# Your deployed frontend URL — used to configure CORS
# For local dev: http://localhost:3000  |  For Vercel: https://your-app.vercel.app
FRONTEND_BASE_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────

# Anthropic API key — only needed if LLM_FALLBACK_PROVIDER=anthropic
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Webhook URL for trip PDF/email export — leave blank to disable
EXPORT_WEBHOOK_URL=

# ── LLM model config — A/B testing ────────────────────────────────────────────
# Supported providers: gemini, openai, anthropic

LLM_PRIMARY_PROVIDER=gemini
LLM_PRIMARY_MODEL=gemini-2.5-flash

# Fallback — called automatically if primary fails or times out
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4o

# Intake — lightweight call to parse chat into structured data (keep fast/cheap)
LLM_INTAKE_PROVIDER=gemini
LLM_INTAKE_MODEL=gemini-2.5-flash
