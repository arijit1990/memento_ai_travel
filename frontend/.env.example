# ── Backend URL ───────────────────────────────────────────────────────────────
# For local dev: http://localhost:8001
# For Vercel: https://your-backend-app.vercel.app
# IMPORTANT: baked into the JS bundle at build time — redeploy frontend when changed
REACT_APP_BACKEND_URL=http://localhost:8001

# ── Supabase ──────────────────────────────────────────────────────────────────
# Both values are in Supabase dashboard → Settings → API
# SUPABASE_URL: the "Project URL" field
# SUPABASE_ANON_KEY: the "anon public" key (safe to expose in frontend)
REACT_APP_SUPABASE_URL=https://<project-ref>.supabase.co
REACT_APP_SUPABASE_ANON_KEY=
